{
	"name": "awto-pi-lot",
	"version": "2.67.68",
	"type": "module",
	"description": "pi-coding-agent extension that adds PPQ.ai provider and their AutoClaw model",
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "npx tsc && shx cp README.md dist/",
		"check": "npm install && npm run build && biome check --write --error-on-warnings ."
	},
	"keywords": [
		"pi",
		"pi-package",
		"pi-extension",
		"coding-agent",
		"ai",
		"llm",
		"cli",
		"tui",
		"agent",
		"ppq",
		"ppq.ai",
		"autoclaw",
		"bitcoin",
		"lightning"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nblockchain/awto-pi-lot.git"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "0.67.68",
		"fp-sdk": "^0.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "^22.10.5",
		"husky": "^9.1.7",
		"shx": "^0.4.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
