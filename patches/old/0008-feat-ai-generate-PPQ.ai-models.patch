From 52903c7b72bcca3e1ade663f0256c74e4e9431ef Mon Sep 17 00:00:00 2001
From: webwarrior-ws <reg@webwarrior.ws>
Date: Sat, 14 Mar 2026 22:06:29 +0100
Subject: [PATCH 08/15] feat(ai): generate PPQ.ai models

Made `generate-models.ts` include PPQ.ai models in the
generated models list.

Supposedly all auto-generated models should have tool support,
but PPQ.ai doesn't provide such information.

Also no information if the model is reasoning. That property is
set to false for all models.
---
 packages/ai/scripts/generate-models.ts |   66 +-
 packages/ai/src/models.generated.ts    | 5536 +++++++++++++++++++++++-
 2 files changed, 5562 insertions(+), 40 deletions(-)

diff --git a/packages/ai/scripts/generate-models.ts b/packages/ai/scripts/generate-models.ts
index 8f5af680..447f6e94 100644
--- a/packages/ai/scripts/generate-models.ts
+++ b/packages/ai/scripts/generate-models.ts
@@ -172,6 +172,43 @@ async function fetchAiGatewayModels(): Promise<Model<any>[]> {
 	}
 }
 
+async function fetchPpqModels(): Promise<Model<any>[]> {
+	try {
+		console.log("Fetching models from PPQ.ai...");
+		const response = await fetch("https://api.ppq.ai/v1/models");
+		const data = await response.json();
+
+		const models: Model<any>[] = [];
+
+		// tool support ???
+		for (const model of data.data) {
+			models.push({
+				id: model.id,
+				name: model.name,
+				api: "openai-completions",
+				baseUrl: "https://api.ppq.ai",
+				provider: "ppq",
+				reasoning: false, // ???
+				input: ["text"],
+				cost: {
+					input: model.pricing.input_per_1M_tokens,
+					output: model.pricing.output_per_1M_tokens,
+					cacheRead: 0,
+					cacheWrite: 0,
+				},
+				contextWindow: model.context_length,
+				maxTokens: 4096,
+			});
+		}
+
+		console.log(`Fetched ${models.length} models from PPQ.ai`);
+		return models;
+	} catch (error) {
+		console.error("Failed to fetch PPQ.ai models:", error);
+		return [];
+	}
+}
